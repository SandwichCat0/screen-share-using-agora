# Agora 开发者凭据 — 从 https://console.agora.io 获取
APP_ID=
APP_CERTIFICATE=

# 服务端口
PORT=3000

# Token 有效期（秒）
TOKEN_EXPIRE=86400

# 允许的 CORS 来源（逗号分隔）
CORS_ORIGINS=https://mdshare.local

# 运行环境（production 时 Cookie 自动加 Secure 标志，要求 HTTPS）
NODE_ENV=production

# ── 卡密系统配置 ──────────────────────────────────────────
# JWT 签名密钥（管理员后台用），请勿泄露
JWT_SECRET=

# 管理员账号（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
